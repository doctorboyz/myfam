// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// Enums
enum UserRole {
  parent
  child
}

enum AccountType {
  bank
  cash
  credit
  wallet
  loan
  invest
}

enum TransactionType {
  income
  expense
  transfer
}

enum BudgetPeriod {
  monthly
  one_time
}

enum BudgetStatus {
  active
  archived
}

enum TransactionStatus {
  pending
  completed
  planned
  void
}

// Models

model Family {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  members User[]
  tags    Tag[]
}

model User {
  id        String   @id @default(uuid())
  name      String   @unique
  password  String?
  role      UserRole @default(child)
  isAdmin   Boolean  @default(false) @map("is_admin")
  avatar    String?
  color     String   @default("#000000")
  familyId  String   @map("family_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  family       Family        @relation(fields: [familyId], references: [id])
  accounts     Account[]
  transactions Transaction[]
  categories   Category[]
  budgets      Budget[]
  lineLink     LineLink?
  tags         Tag[]

  // Audit trail relations
  createdAccounts      Account[]         @relation("AccountCreator")
  updatedAccounts      Account[]         @relation("AccountUpdater")
  deletedAccounts      Account[]         @relation("AccountDeleter")
  deletedReconciliations Reconciliation[] @relation("ReconciliationDeleter")
  deletedCategoryGroups CategoryGroup[]  @relation("CategoryGroupDeleter")
  deletedCategories    Category[]        @relation("CategoryDeleter")
  updatedTransactions  Transaction[]     @relation("TransactionUpdater")
  deletedTransactions  Transaction[]     @relation("TransactionDeleter")
  deletedTags          Tag[]             @relation("TagDeleter")
  deletedTransactionTags TransactionTag[] @relation("TransactionTagDeleter")
  updatedBudgets       Budget[]          @relation("BudgetUpdater")
  deletedBudgets       Budget[]          @relation("BudgetDeleter")
}

model Account {
  id        String      @id @default(uuid())
  name      String
  type      AccountType
  balance   Decimal     @default(0)
  color     String      @default("#000000")
  icon      String?
  accountNo String?     @map("account_no")
  alias     String?
  ownerId   String      @map("owner_id")
  status    String      @default("active")

  owner                User             @relation(fields: [ownerId], references: [id])
  incomingTransactions Transaction[]    @relation("Incoming")
  outgoingTransactions Transaction[]    @relation("Outgoing")
  reconciliations      Reconciliation[]

  createdById String?  @map("created_by_id")
  createdBy   User?    @relation("AccountCreator", fields: [createdById], references: [id])
  updatedById String?  @map("updated_by_id")
  updatedBy   User?    @relation("AccountUpdater", fields: [updatedById], references: [id])
  deletedById String?  @map("deleted_by_id")
  deletedBy   User?    @relation("AccountDeleter", fields: [deletedById], references: [id])
  deletedAt   DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model Reconciliation {
  id              String  @id @default(uuid())
  accountId       String  @map("account_id")
  account         Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  previousBalance Decimal @map("previous_balance")
  newBalance      Decimal @map("new_balance")
  difference      Decimal
  note            String?
  performedById   String  @map("performed_by_id")

  deletedById String?   @map("deleted_by_id")
  deletedBy   User?    @relation("ReconciliationDeleter", fields: [deletedById], references: [id])
  deletedAt   DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
}

model CategoryGroup {
  id         String     @id @default(uuid())
  name       String
  type       String
  isCustom   Boolean    @default(false)
  categories Category[]

  deletedById String?   @map("deleted_by_id")
  deletedBy   User?     @relation("CategoryGroupDeleter", fields: [deletedById], references: [id])
  deletedAt   DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model Category {
  id      String        @id @default(uuid())
  name    String
  groupId String        @map("group_id")
  group   CategoryGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  userId String? @map("user_id")
  user   User?   @relation(fields: [userId], references: [id])

  transactions Transaction[]

  deletedById String?   @map("deleted_by_id")
  deletedBy   User?     @relation("CategoryDeleter", fields: [deletedById], references: [id])
  deletedAt   DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model Transaction {
  id          String            @id @default(uuid())
  amount      Decimal           @default(0)
  planAmount  Decimal?          @map("plan_amount")
  date        DateTime
  type        TransactionType
  description String?
  status      TransactionStatus @default(completed)

  accountId String?  @map("account_id")
  account   Account? @relation("Outgoing", fields: [accountId], references: [id], onDelete: Cascade)

  toAccountId String?  @map("to_account_id")
  toAccount   Account? @relation("Incoming", fields: [toAccountId], references: [id])

  categoryId String?   @map("category_id")
  category   Category? @relation(fields: [categoryId], references: [id])

  // Budget Relation
  budgetId String? @map("budget_id")
  budget   Budget? @relation(fields: [budgetId], references: [id])

  createdById String @map("created_by_id")
  createdBy   User   @relation(fields: [createdById], references: [id])

  // Extra fields
  fee       Decimal? @default(0)
  slipImage String?  @map("slip_image")

  // Tags (many-to-many via TransactionTag)
  tagRecords TransactionTag[]

  updatedById String?  @map("updated_by_id")
  updatedBy   User?    @relation("TransactionUpdater", fields: [updatedById], references: [id])
  deletedById String?  @map("deleted_by_id")
  deletedBy   User?    @relation("TransactionDeleter", fields: [deletedById], references: [id])
  deletedAt   DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model Tag {
  id       String  @id @default(uuid())
  name     String
  userId   String  @map("user_id")
  color    String?
  familyId String  @map("family_id")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  family Family @relation(fields: [familyId], references: [id], onDelete: Cascade)

  transactions TransactionTag[]

  deletedById String?   @map("deleted_by_id")
  deletedBy   User?     @relation("TagDeleter", fields: [deletedById], references: [id])
  deletedAt   DateTime? @map("deleted_at")

  @@unique([name, userId])
  @@map("tags")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}

model TransactionTag {
  id            String      @id @default(uuid())
  transactionId String     @map("transaction_id")
  tagId         String     @map("tag_id")

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  tag         Tag         @relation(fields: [tagId], references: [id], onDelete: Cascade)

  deletedById String?   @map("deleted_by_id")
  deletedBy   User?     @relation("TransactionTagDeleter", fields: [deletedById], references: [id])
  deletedAt   DateTime? @map("deleted_at")

  @@unique([transactionId, tagId])
  @@map("transaction_tags")

  createdAt DateTime @default(now()) @map("created_at")
}

model LineLink {
  id          String   @id @default(uuid())
  lineUserId  String   @unique @map("line_user_id")
  userId      String   @unique @map("user_id")
  displayName String?  @map("display_name")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("line_links")
}

model Budget {
  id          String       @id @default(uuid())
  title       String
  description String?
  period      BudgetPeriod
  limit       Decimal
  startDate   DateTime?    @map("start_date")
  endDate     DateTime?    @map("end_date")
  status      BudgetStatus @default(active)
  icon        String?
  color       String?

  transactions Transaction[]

  createdById String @map("created_by_id")
  createdBy   User   @relation(fields: [createdById], references: [id])

  updatedById String?  @map("updated_by_id")
  updatedBy   User?    @relation("BudgetUpdater", fields: [updatedById], references: [id])
  deletedById String?  @map("deleted_by_id")
  deletedBy   User?    @relation("BudgetDeleter", fields: [deletedById], references: [id])
  deletedAt   DateTime? @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
}